
# --- Django ---
# A long random string. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=0$o3d&+)!kh6=ea6a0z1b@!7%$*a9of01lh03$%501!t#_vzqy

# Set to "False" in production.
DJANGO_DEBUG=True

# Comma-separated list of allowed hosts (used when DEBUG is False).
DJANGO_ALLOWED_HOSTS=inamai.pythonanywhere.com,127.0.0.1

# --- Google Gemini ---
# Get a free API key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Which Gemini model to use. Good, fast, cheap default below.
GEMINI_MODEL=gemini-3.5-flash

# --- Alpha Vantage (fallback data source when Yahoo rate-limits, e.g. on PythonAnywhere) ---
# Get a free key at https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=your-alphavantage-key-here

# --- Finnhub (primary fallback — 60 requests/min free, per-key limit) ---
# Get a free key at https://finnhub.io/register
FINNHUB_API_KEY=your-finnhub-key-here
