# =========================================================
#  Environment variables for the AI Investment Research Agent
#  Copy this file to ".env" and fill in the real values.
#  NEVER commit your real .env file to version control.
# =========================================================

# --- Django ---
# A long random string. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# Set to "False" in production.
DJANGO_DEBUG=True

# Comma-separated list of allowed hosts (used when DEBUG is False).
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# --- Google Gemini ---
# Get a free API key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Which Gemini model to use. Good, fast, cheap default below.
GEMINI_MODEL=gemini-flash-latest
